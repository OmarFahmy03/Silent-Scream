  m_Name: 
  m_EditorClassIdentifier: UnityEngine.UI::UnityEngine.UI.Text
  m_Material: {fileID: 0}
  m_Color: {r: 0.19607843, g: 0.19607843, b: 0.19607843, a: 1}
  m_RaycastTarget: 1
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_FontData:
    m_Font: {fileID: 12800000, guid: d05c2321be0ddcf4c84ff16a61f9337f, type: 3}
    m_FontSize: 26
    m_FontStyle: 0
    m_BestFit: 0
    m_MinSize: 2
    m_MaxSize: 42
    m_Alignment: 0
    m_AlignByGeometry: 0
    m_RichText: 1
    m_HorizontalOverflow: 0
    m_VerticalOverflow: 0
    m_LineSpacing: 1
  m_Text: "On my left is where it all started.\nIn the back of the hallway, I heard
    screaming \u2014 it was on the same line as my room.\nOn the opposite side of
    the corridor, near my <b>escape route</b>, stands the <color=red>next target</color>.
    His room faced that of the previous patient.\nLook <b>behind you</b> \u2014 you\u2019ll
    find the two rooms you need. The first is near the <color=red>monster</color>.\r\nI
    keep hearing his <b>groan</b>... he\u2019s coming for <color=red>YOU</color>.\r\nIt
    all ends with <b><color=red>YOU</color></b>, and where you wake up."
